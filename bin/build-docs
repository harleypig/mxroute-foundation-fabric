#!/usr/bin/env bash
#
# Regenerate (or, with --check, verify) each module's terraform-docs README.
# Both the regenerate hook (.pre-commit-config-fix.yaml) and the check gate
# (.pre-commit-config.yaml) call this, so they share one code path and cannot
# drift apart. Explicitly passes -c .terraform-docs.yml (unlike the stock
# antonbabenko terraform_docs hook, which ignores it), so the generated block
# carries the markdownlint capture/disable/restore wrapper.
#
# Usage:
#   bin/build-docs            # regenerate every module README in place
#   bin/build-docs --check    # fail if any README is stale (no writes)
#
# Uses a locally installed terraform-docs (see .claude/CONVENTIONS.md).

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

check=""
if [[ "${1:-}" == "--check" ]]; then
  check="--output-check"
fi

rc=0

for module in modules/*/; do
  if ! terraform-docs $check -c .terraform-docs.yml "$module" >/dev/null; then
    echo "terraform-docs: $module README is stale (run: bin/build-docs)" >&2
    rc=1
  fi
done

exit $rc
